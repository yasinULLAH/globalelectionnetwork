generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────
//  ELECTIONS
// ─────────────────────────────────────────────────────────

model Election {
  id                    String         @id @default(cuid())
  name                  String
  country               String         @default("Pakistan")
  electionType          ElectionType   @default(General)
  region                String
  province              String
  date                  DateTime
  status                ElectionStatus @default(upcoming)
  totalSeats            Int
  totalRegisteredVoters Int
  description           String?
  flagEmoji             String         @default("🗳️")
  isActive              Boolean        @default(false)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  provinces      Province[]
  constituencies Constituency[]
  parties        Party[]
  candidates     Candidate[]
  observers      Observer[]
  resultEntries  ResultEntry[]
  liveUpdates    LiveUpdate[]
}

enum ElectionType {
  General
  Provincial
  ByElection
  Senate
  LocalBodies
}

enum ElectionStatus {
  upcoming
  live
  completed
}

// ─────────────────────────────────────────────────────────
//  PARTIES
// ─────────────────────────────────────────────────────────

model Party {
  id          String  @id @default(cuid())
  name        String
  shortName   String
  color       String
  bgColor     String
  foundedYear Int?
  ideology    String?
  electionId  String

  election      Election    @relation(fields: [electionId], references: [id], onDelete: Cascade)
  candidates    Candidate[]
  resultEntries ResultEntry[]
  seats         PartySeats?

  @@unique([shortName, electionId])
}

model PartySeats {
  id         String @id @default(cuid())
  partyId    String @unique
  seats      Int    @default(0)
  totalVotes Int    @default(0)

  party Party @relation(fields: [partyId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────
//  PROVINCES
// ─────────────────────────────────────────────────────────

model Province {
  id         String  @id @default(cuid())
  name       String
  code       String
  electionId String

  election      Election       @relation(fields: [electionId], references: [id], onDelete: Cascade)
  constituencies Constituency[]

  @@unique([code, electionId])
}

// ─────────────────────────────────────────────────────────
//  CONSTITUENCIES
// ─────────────────────────────────────────────────────────

model Constituency {
  id                String           @id @default(cuid())
  name              String
  code              String
  provinceId        String
  district          String
  type              ConstituencyType @default(national)
  registeredVoters  Int
  reportedStations  Int              @default(0)
  totalStations     Int
  lat               Float?
  lng               Float?
  electionId        String

  election       Election       @relation(fields: [electionId], references: [id], onDelete: Cascade)
  province       Province       @relation(fields: [provinceId], references: [id])
  candidates     Candidate[]
  pollingStations PollingStation[]
  resultEntries  ResultEntry[]

  @@unique([code, electionId])
}

enum ConstituencyType {
  national
  provincial
}

// ─────────────────────────────────────────────────────────
//  POLLING STATIONS
// ─────────────────────────────────────────────────────────

model PollingStation {
  id               String  @id @default(cuid())
  name             String
  address          String
  constituencyId   String
  registeredVoters Int
  reported         Boolean @default(false)
  observerId       String?

  constituency  Constituency  @relation(fields: [constituencyId], references: [id], onDelete: Cascade)
  observer      Observer?     @relation(fields: [observerId], references: [id])
  resultEntries ResultEntry[]
}

// ─────────────────────────────────────────────────────────
//  CANDIDATES
// ─────────────────────────────────────────────────────────

model Candidate {
  id             String  @id @default(cuid())
  name           String
  partyId        String
  constituencyId String
  electionId     String
  votes          Int     @default(0)
  likes          Int     @default(0)
  bio            String?
  age            Int?
  education      String?
  initials       String
  profession     String?
  photoUrl       String?

  party         Party         @relation(fields: [partyId], references: [id])
  constituency  Constituency  @relation(fields: [constituencyId], references: [id])
  election      Election      @relation(fields: [electionId], references: [id], onDelete: Cascade)
  resultEntries ResultEntry[]
}

// ─────────────────────────────────────────────────────────
//  OBSERVERS
// ─────────────────────────────────────────────────────────

model Observer {
  id                 String         @id @default(cuid())
  name               String
  email              String         @unique
  phone              String?
  cnic               String?
  pollingStationName String?
  status             ObserverStatus @default(pending)
  resultsSubmitted   Int            @default(0)
  lastActivity       DateTime?
  joinedAt           DateTime       @default(now())
  electionId         String

  election       Election         @relation(fields: [electionId], references: [id], onDelete: Cascade)
  pollingStation PollingStation[]
  resultEntries  ResultEntry[]
}

enum ObserverStatus {
  active
  inactive
  pending
}

// ─────────────────────────────────────────────────────────
//  RESULT ENTRIES (observer submissions)
// ─────────────────────────────────────────────────────────

model ResultEntry {
  id                 String   @id @default(cuid())
  candidateId        String
  candidateName      String
  partyId            String
  pollingStationId   String
  pollingStationName String
  constituencyId     String
  electionId         String
  votes              Int
  submittedAt        DateTime @default(now())
  submittedBy        String
  verified           Boolean  @default(false)
  flagged            Boolean  @default(false)
  observerId         String?

  candidate    Candidate      @relation(fields: [candidateId], references: [id])
  party        Party          @relation(fields: [partyId], references: [id])
  pollingStation PollingStation @relation(fields: [pollingStationId], references: [id])
  constituency Constituency   @relation(fields: [constituencyId], references: [id])
  election     Election       @relation(fields: [electionId], references: [id], onDelete: Cascade)
  observer     Observer?      @relation(fields: [observerId], references: [id])
}

// ─────────────────────────────────────────────────────────
//  LIVE UPDATES
// ─────────────────────────────────────────────────────────

model LiveUpdate {
  id                String           @id @default(cuid())
  message           String
  timestamp         DateTime         @default(now())
  type              LiveUpdateType
  constituencyCode  String?
  electionId        String

  election Election @relation(fields: [electionId], references: [id], onDelete: Cascade)
}

enum LiveUpdateType {
  result
  alert
  update
  milestone
}

// ─────────────────────────────────────────────────────────
//  USERS / AUTH
// ─────────────────────────────────────────────────────────

model User {
  id         String   @id @default(cuid())
  name       String
  email      String   @unique
  password   String
  role       UserRole @default(public)
  observerId String?
  createdAt  DateTime @default(now())
}

enum UserRole {
  admin
  observer
  public
}
